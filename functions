# Show size of a file or directory
function fs() {
  if du -b /dev/null > /dev/null 2>&1; then
    local arg=-sbh
  else
    local arg=-sh
  fi
  if [[ -n "$@" ]]; then
    du $arg -- "$@"
  else
    du $arg .[^.]* ./*
  fi
}

# mkdir and cd into it
function mkcdir() {
  mkdir -p -- "$1" && cd -P -- "$1"
}
